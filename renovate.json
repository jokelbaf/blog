{
	"extends": [
		"github>nuxt/renovate-config-nuxt"
	],
	"lockFileMaintenance": {
		"enabled": true
	},
	"packageRules": [
		{ "matchManagers": ["pnpm"], "matchPaths": ["website/**"] },
   		{ "matchManagers": ["cargo"], "matchPaths": ["wasm/**"] },
		{ "matchDepTypes": ["resolutions"], "enabled": false }],
	"postUpdateOptions": ["pnpmDedupe"]
}
